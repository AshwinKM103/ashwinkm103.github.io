source 'https://rubygems.org'

# Build with a modern, self-hosted Jekyll (deployed via GitHub Actions),
# NOT the github-pages gem — this frees us from GitHub Pages' plugin whitelist
# and pinned Jekyll version. See .github/workflows/deploy.yml.
gem 'jekyll', '~> 4.3'
gem 'webrick', '~> 1.8'

group :jekyll_plugins do
  gem 'jekyll-feed'
  gem 'jekyll-seo-tag'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jekyll-paginate'
  gem 'jekyll-gist'
  gem 'jemoji'
end
